{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Create an E-Pipe service named 'Epipe-VLAN-3459-colo-to-branch' for customer 1995 (NE service ID 9491). Connect device 192.168.26.219 on port 1/1/c1/3 to device 192.168.165.111 on port lag-Broadcom8-4x25GE using VLAN 3459. MTU is 1450. Use SDP 219111 and 111219."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-3459-colo-to-branch\",\n    \"customer-id\": 1995,\n    \"ne-service-id\": 9491,\n    \"mtu\": 1450,\n    \"site-a.device-id\": \"192.168.26.219\",\n    \"site-a.endpoint[0].port-id\": \"1/1/c1/3\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 3459,\n    \"site-b.device-id\": \"192.168.165.111\",\n    \"site-b.endpoint[0].port-id\": \"lag-Broadcom8-4x25GE\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 3459,\n    \"sdp[0].sdp-id\": \"219111\",\n    \"sdp[0].source-device-id\": \"192.168.26.219\",\n    \"sdp[0].destination-device-id\": \"192.168.165.111\",\n    \"sdp[1].sdp-id\": \"111219\",\n    \"sdp[1].source-device-id\": \"192.168.165.111\",\n    \"sdp[1].destination-device-id\": \"192.168.26.219\"\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Before creating the E-Pipe service, set up the underlying MPLS tunnel. Source: 192.168.142.90, Destination: 192.168.204.174. SDP ID: 90174. Name: 'SDP-from-192-168-142-90-to-192-168-204-174'."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"tunnel\",\n  \"template_name\": \"MPLSTunnelsWithBGP\",\n  \"fill_values\": {\n    \"source-ne-id\": \"192.168.142.90\",\n    \"sdp-id\": \"90174\",\n    \"destination-ne-id\": \"192.168.204.174\",\n    \"name\": \"SDP-from-192-168-142-90-to-192-168-204-174\"\n  }\n}"}]}
