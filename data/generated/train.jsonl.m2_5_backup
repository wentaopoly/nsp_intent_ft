"172.20.213.22\",\n    \"site[0].interface[0].ipv4.primary.prefix-length\": 30,\n    \"site[0].interface[1].interface-name\": \"Delta-Cluster-Worker-1\",\n    \"site[0].interface[1].sap.port-id\": \"lag-Juniper6-2x100GE\",\n    \"site[0].interface[1].ipv4.primary.address\": \"100.104.230.176\",\n    \"site[0].interface[1].ipv4.primary.prefix-length\": 31,\n    \"site[1].site-name\": \"VPRN-7471-SmartGrid\",\n    \"site[1].device-id\": \"192.168.165.84\",\n    \"site[1].ne-service-id\": 7471,\n    \"site[1].route-distinguisher\": \"65281:7471\",\n    \"site[1].vrf-import\": [\n      \"SmartGrid-VRF-Import\"\n    ],\n    \"site[1].vrf-export\": [\n      \"SmartGrid-VRF-Export\"\n    ],\n    \"site[1].interface[0].interface-name\": \"Phoenix-Cluster-Master\",\n    \"site[1].interface[0].sap.port-id\": \"lag-Juniper8-2x100GE\",\n    \"site[1].interface[0].ipv4.primary.address\": \"100.109.51.254\",\n    \"site[1].interface[0].ipv4.primary.prefix-length\": 30,\n    \"site[1].interface[1].interface-name\": \"Phoenix-Cluster-Worker-1\",\n    \"site[1].interface[1].sap.port-id\": \"lag-Nokia9-2x100GE\",\n    \"site[1].interface[1].ipv4.primary.address\": \"10.3.26.99\",\n    \"site[1].interface[1].ipv4.primary.prefix-length\": 28\n  }\n}"}]}
