    \"site[0].interface[0].sap.port-id\": \"2/2/c9/2\",\n    \"site[0].interface[0].ipv4.primary.address\": \"172.26.22.108\",\n    \"site[0].interface[0].ipv4.primary.prefix-length\": 28,\n    \"site[0].interface[1].interface-name\": \"Neptune-Cluster-Worker-1\",\n    \"site[0].interface[1].sap.port-id\": \"lag-Mellanox4-4x10GE\",\n    \"site[0].interface[1].ipv4.primary.address\": \"100.109.228.4\",\n    \"site[0].interface[1].ipv4.primary.prefix-length\": 28,\n    \"site[0].interface[2].interface-name\": \"Neptune-Cluster-Worker-2\",\n    \"site[0].interface[2].sap.port-id\": \"1/2/c8/1\",\n    \"site[0].interface[2].ipv4.primary.address\": \"172.22.51.83\",\n    \"site[0].interface[2].ipv4.primary.prefix-length\": 30,\n    \"site[1].site-name\": \"VPRN-5977-OptiRoute\",\n    \"site[1].device-id\": \"192.168.65.165\",\n    \"site[1].ne-service-id\": 5977,\n    \"site[1].route-distinguisher\": \"64607:5977\",\n    \"site[1].vrf-import\": [\n      \"OptiRoute-VRF-Import\"\n    ],\n    \"site[1].vrf-export\": [\n      \"OptiRoute-VRF-Export\"\n    ],\n    \"site[1].interface[0].interface-name\": \"Polaris-Cluster-Master\",\n    \"site[1].interface[0].sap.port-id\": \"lag-Juniper1-4x25GE\",\n    \"site[1].interface[0].ipv4.primary.address\": \"100.92.140.182\",\n    \"site[1].interface[0].ipv4.primary.prefix-length\": 30,\n    \"site[1].interface[1].interface-name\": \"Polaris-Cluster-Worker-1\",\n    \"site[1].interface[1].sap.port-id\": \"1/2/c8/1\",\n    \"site[1].interface[1].ipv4.primary.address\": \"172.22.53.249\",\n    \"site[1].interface[1].ipv4.primary.prefix-length\": 24,\n    \"site[1].interface[2].interface-name\": \"Polaris-Cluster-Worker-2\",\n    \"site[1].interface[2].sap.port-id\": \"2/2/c2/3\",\n    \"site[1].interface[2].ipv4.primary.address\": \"10.116.165.218\",\n    \"site[1].interface[2].ipv4.primary.prefix-length\": 31\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Deploy an ePIPE service 'Epipe-VLAN-1508-colo-to-colo' with the following parameters: customer ID 7205, service ID 7334, MTU 9212. Site A is on device 192.168.169.70 port lag-Mellanox12-2x100GE, Site B is on device 192.168.63.205 port 2/1/c12/4. VLAN tag is 1508. SDP IDs are 70205 (A to B) and 20570 (B to A)."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-1508-colo-to-colo\",\n    \"customer-id\": 7205,\n    \"ne-service-id\": 7334,\n    \"mtu\": 9212,\n    \"site-a.device-id\": \"192.168.169.70\",\n    \"site-a.endpoint[0].port-id\": \"lag-Mellanox12-2x100GE\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 1508,\n    \"site-b.device-id\": \"192.168.63.205\",\n    \"site-b.endpoint[0].port-id\": \"2/1/c12/4\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 1508,\n    \"sdp[0].sdp-id\": \"70205\",\n    \"sdp[0].source-device-id\": \"192.168.169.70\",\n    \"sdp[0].destination-device-id\": \"192.168.63.205\",\n    \"sdp[1].sdp-id\": \"20570\",\n    \"sdp[1].source-device-id\": \"192.168.63.205\",\n    \"sdp[1].destination-device-id\": \"192.168.169.70\"\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Our network requires a new tunnel from 192.168.67.202 to 192.168.187.136 for service transport. SDP ID is 202136. Let's call it 'SDP-from-192-168-67-202-to-192-168-187-136'. Use BGP-based MPLS."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"tunnel\",\n  \"template_name\": \"MPLSTunnelsWithBGP\",\n  \"fill_values\": {\n    \"source-ne-id\": \"192.168.67.202\",\n    \"sdp-id\": \"202136\",\n    \"destination-ne-id\": \"192.168.187.136\",\n    \"name\": \"SDP-from-192-168-67-202-to-192-168-187-136\"\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Please provision an E-Pipe between two routers. Details: Name='Epipe-VLAN-694-datacenter-to-lab', Customer=6137, ServiceID=8542, MTU=1500. Router A (192.168.162.152) port lag-Cisco5-2x25GE VLAN 694, Router B (192.168.10.197) port lag-HPE5-4x10GE VLAN 694. SDP 152197 for A→B, SDP 197152 for B→A."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-694-datacenter-to-lab\",\n    \"customer-id\": 6137,\n    \"ne-service-id\": 8542,\n    \"mtu\": 1500,\n    \"site-a.device-id\": \"192.168.162.152\",\n    \"site-a.endpoint[0].port-id\": \"lag-Cisco5-2x25GE\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 694,\n    \"site-b.device-id\": \"192.168.10.197\",\n    \"site-b.endpoint[0].port-id\": \"lag-HPE5-4x10GE\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 694,\n    \"sdp[0].sdp-id\": \"152197\",\n    \"sdp[0].source-device-id\": \"192.168.162.152\",\n    \"sdp[0].destination-device-id\": \"192.168.10.197\",\n    \"sdp[1].sdp-id\": \"197152\",\n    \"sdp[1].source-device-id\": \"192.168.10.197\",\n    \"sdp[1].destination-device-id\": \"192.168.162.152\"\n  }\n}"}]}
