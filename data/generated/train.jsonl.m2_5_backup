].interface-name\": \"Quasar-Cluster-Worker-1\",\n    \"site[0].interface[1].sap.port-id\": \"lag-AFOR10-4x25GE\",\n    \"site[0].interface[1].ipv4.primary.address\": \"10.154.143.230\",\n    \"site[0].interface[1].ipv4.primary.prefix-length\": 31,\n    \"site[1].site-name\": \"VPRN-4729-NetFlow\",\n    \"site[1].device-id\": \"192.168.111.216\",\n    \"site[1].ne-service-id\": 4729,\n    \"site[1].route-distinguisher\": \"64631:4729\",\n    \"site[1].vrf-import\": [\n      \"NetFlow-VRF-Import\"\n    ],\n    \"site[1].vrf-export\": [\n      \"NetFlow-VRF-Export\"\n    ],\n    \"site[1].interface[0].interface-name\": \"Castor-Cluster-Master\",\n    \"site[1].interface[0].sap.port-id\": \"lag-Juniper3-2x100GE\",\n    \"site[1].interface[0].ipv4.primary.address\": \"10.176.198.6\",\n    \"site[1].interface[0].ipv4.primary.prefix-length\": 24,\n    \"site[1].interface[1].interface-name\": \"Castor-Cluster-Worker-1\",\n    \"site[1].interface[1].sap.port-id\": \"1/1/c2/1\",\n    \"site[1].interface[1].ipv4.primary.address\": \"100.110.153.206\",\n    \"site[1].interface[1].ipv4.primary.prefix-length\": 31\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Our customer (ID: 4941) needs a dedicated Layer 2 connection between their 192.168.142.167 and 192.168.188.12 routers. Please create an E-Pipe service named 'Epipe-VLAN-276-lab-to-colo' with service ID 9185. Use VLAN 276 on ports lag-Intel3-4x25GE (site A) and lag-Intel6-2x100GE (site B). MTU should be 1500. The SDP tunnel IDs are 16712 and 12167."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-276-lab-to-colo\",\n    \"customer-id\": 4941,\n    \"ne-service-id\": 9185,\n    \"mtu\": 1500,\n    \"site-a.device-id\": \"192.168.142.167\",\n    \"site-a.endpoint[0].port-id\": \"lag-Intel3-4x25GE\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 276,\n    \"site-b.device-id\": \"192.168.188.12\",\n    \"site-b.endpoint[0].port-id\": \"lag-Intel6-2x100GE\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 276,\n    \"sdp[0].sdp-id\": \"16712\",\n    \"sdp[0].source-device-id\": \"192.168.142.167\",\n    \"sdp[0].destination-device-id\": \"192.168.188.12\",\n    \"sdp[1].sdp-id\": \"12167\",\n    \"sdp[1].source-device-id\": \"192.168.188.12\",\n    \"sdp[1].destination-device-id\": \"192.168.142.167\"\n  }\n}"}]}
