face[0].sap.port-id\": \"lag-Cisco5-4x25GE\",\n    \"site[0].interface[0].ipv4.primary.address\": \"10.113.126.6\",\n    \"site[0].interface[0].ipv4.primary.prefix-length\": 28,\n    \"site[0].interface[1].interface-name\": \"Deneb-Cluster-Worker-1\",\n    \"site[0].interface[1].sap.port-id\": \"lag-Arista5-4x10GE\",\n    \"site[0].interface[1].ipv4.primary.address\": \"172.22.25.47\",\n    \"site[0].interface[1].ipv4.primary.prefix-length\": 28,\n    \"site[0].interface[2].interface-name\": \"Deneb-Cluster-Worker-2\",\n    \"site[0].interface[2].sap.port-id\": \"2/1/c12/4\",\n    \"site[0].interface[2].ipv4.primary.address\": \"10.150.243.239\",\n    \"site[0].interface[2].ipv4.primary.prefix-length\": 28,\n    \"site[1].site-name\": \"VPRN-4644-StarNet\",\n    \"site[1].device-id\": \"192.168.28.62\",\n    \"site[1].ne-service-id\": 4644,\n    \"site[1].route-distinguisher\": \"64747:4644\",\n    \"site[1].vrf-import\": [\n      \"StarNet-VRF-Import\"\n    ],\n    \"site[1].vrf-export\": [\n      \"StarNet-VRF-Export\"\n    ],\n    \"site[1].interface[0].interface-name\": \"Phoenix-Cluster-Master\",\n    \"site[1].interface[0].sap.port-id\": \"1/1/c6/1\",\n    \"site[1].interface[0].ipv4.primary.address\": \"10.165.37.103\",\n    \"site[1].interface[0].ipv4.primary.prefix-length\": 24,\n    \"site[1].interface[1].interface-name\": \"Phoenix-Cluster-Worker-1\",\n    \"site[1].interface[1].sap.port-id\": \"2/1/c10/3\",\n    \"site[1].interface[1].ipv4.primary.address\": \"100.75.187.243\",\n    \"site[1].interface[1].ipv4.primary.prefix-length\": 24,\n    \"site[1].interface[2].interface-name\": \"Phoenix-Cluster-Worker-2\",\n    \"site[1].interface[2].sap.port-id\": \"lag-AMD11-4x25GE\",\n    \"site[1].interface[2].ipv4.primary.address\": \"100.83.77.230\",\n    \"site[1].interface[2].ipv4.primary.prefix-length\": 30\n  }\n}"}]}
