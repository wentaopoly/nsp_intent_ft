{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Please provision an E-Pipe between two routers. Details: Name='Epipe-VLAN-1587-hub-to-pop', Customer=9932, ServiceID=6273, MTU=1400. Router A (192.168.88.188) port 1/2/c7/3 VLAN 1587, Router B (192.168.65.27) port lag-Mellanox3-2x25GE VLAN 1587. SDP 18827 for A→B, SDP 27188 for B→A."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-1587-hub-to-pop\",\n    \"customer-id\": 9932,\n    \"ne-service-id\": 6273,\n    \"mtu\": 1400,\n    \"site-a.device-id\": \"192.168.88.188\",\n    \"site-a.endpoint[0].port-id\": \"1/2/c7/3\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 1587,\n    \"site-b.device-id\": \"192.168.65.27\",\n    \"site-b.endpoint[0].port-id\": \"lag-Mellanox3-2x25GE\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 1587,\n    \"sdp[0].sdp-id\": \"18827\",\n    \"sdp[0].source-device-id\": \"192.168.88.188\",\n    \"sdp[0].destination-device-id\": \"192.168.65.27\",\n    \"sdp[1].sdp-id\": \"27188\",\n    \"sdp[1].source-device-id\": \"192.168.65.27\",\n    \"sdp[1].destination-device-id\": \"192.168.88.188\"\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Our network requires a new tunnel from 192.168.122.182 to 192.168.81.80 for service transport. SDP ID is 18280. Let's call it 'SDP-from-192-168-122-182-to-192-168-81-80'. Use BGP-based MPLS."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"tunnel\",\n  \"template_name\": \"MPLSTunnelsWithBGP\",\n  \"fill_values\": {\n    \"source-ne-id\": \"192.168.122.182\",\n    \"sdp-id\": \"18280\",\n    \"destination-ne-id\": \"192.168.81.80\",\n    \"name\": \"SDP-from-192-168-122-182-to-192-168-81-80\"\n  }\n}"}]}
