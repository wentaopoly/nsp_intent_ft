{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Create epipe 'Epipe-VLAN-3295-headquarters-to-colo' for customer 5936 connecting 192.168.3.97 (port 2/2/c9/4) to 192.168.105.177 (port lag-Intel5-2x100GE) on VLAN 3295. Service ID: 2746, MTU: 9000. SDP IDs: 97177 and 17797."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-3295-headquarters-to-colo\",\n    \"customer-id\": 5936,\n    \"ne-service-id\": 2746,\n    \"mtu\": 9000,\n    \"site-a.device-id\": \"192.168.3.97\",\n    \"site-a.endpoint[0].port-id\": \"2/2/c9/4\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 3295,\n    \"site-b.device-id\": \"192.168.105.177\",\n    \"site-b.endpoint[0].port-id\": \"lag-Intel5-2x100GE\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 3295,\n    \"sdp[0].sdp-id\": \"97177\",\n    \"sdp[0].source-device-id\": \"192.168.3.97\",\n    \"sdp[0].destination-device-id\": \"192.168.105.177\",\n    \"sdp[1].sdp-id\": \"17797\",\n    \"sdp[1].source-device-id\": \"192.168.105.177\",\n    \"sdp[1].destination-device-id\": \"192.168.3.97\"\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Our customer (ID: 6318) needs a dedicated Layer 2 connection between their 192.168.238.146 and 192.168.164.231 routers. Please create an E-Pipe service named 'Epipe-VLAN-953-remote-site-to-office' with service ID 5646. Use VLAN 953 on ports lag-Dell-NAR9-4x25GE (site A) and lag-AMD2-2x100GE (site B). MTU should be 9100. The SDP tunnel IDs are 146231 and 231146."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-953-remote-site-to-office\",\n    \"customer-id\": 6318,\n    \"ne-service-id\": 5646,\n    \"mtu\": 9100,\n    \"site-a.device-id\": \"192.168.238.146\",\n    \"site-a.endpoint[0].port-id\": \"lag-Dell-NAR9-4x25GE\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 953,\n    \"site-b.device-id\": \"192.168.164.231\",\n    \"site-b.endpoint[0].port-id\": \"lag-AMD2-2x100GE\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 953,\n    \"sdp[0].sdp-id\": \"146231\",\n    \"sdp[0].source-device-id\": \"192.168.238.146\",\n    \"sdp[0].destination-device-id\": \"192.168.164.231\",\n    \"sdp[1].sdp-id\": \"231146\",\n    \"sdp[1].source-device-id\": \"192.168.164.231\",\n    \"sdp[1].destination-device-id\": \"192.168.238.146\"\n  }\n}"}]}
