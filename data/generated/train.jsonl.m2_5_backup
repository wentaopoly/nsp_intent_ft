p.port-id\": \"lag-Broadcom7-2x25GE\",\n    \"site[0].interface[1].ipv4.primary.address\": \"10.214.66.95\",\n    \"site[0].interface[1].ipv4.primary.prefix-length\": 24,\n    \"site[0].interface[2].interface-name\": \"Epsilon-Cluster-Worker-2\",\n    \"site[0].interface[2].sap.port-id\": \"lag-Arista5-2x100GE\",\n    \"site[0].interface[2].ipv4.primary.address\": \"100.96.42.119\",\n    \"site[0].interface[2].ipv4.primary.prefix-length\": 28\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Set up an E-Line point-to-point Ethernet service. Service name: 'Epipe-VLAN-817-headquarters-to-datacenter'. Customer: 5280. NE service ID: 9700. MTU: 9100. Site A: device 192.168.196.2, port 1/1/c4/3, VLAN 817. Site B: device 192.168.19.137, port 1/2/c9/3, VLAN 817. Use SDP 2137 from A to B and SDP 1372 from B to A."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-817-headquarters-to-datacenter\",\n    \"customer-id\": 5280,\n    \"ne-service-id\": 9700,\n    \"mtu\": 9100,\n    \"site-a.device-id\": \"192.168.196.2\",\n    \"site-a.endpoint[0].port-id\": \"1/1/c4/3\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 817,\n    \"site-b.device-id\": \"192.168.19.137\",\n    \"site-b.endpoint[0].port-id\": \"1/2/c9/3\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 817,\n    \"sdp[0].sdp-id\": \"2137\",\n    \"sdp[0].source-device-id\": \"192.168.196.2\",\n    \"sdp[0].destination-device-id\": \"192.168.19.137\",\n    \"sdp[1].sdp-id\": \"1372\",\n    \"sdp[1].source-device-id\": \"192.168.19.137\",\n    \"sdp[1].destination-device-id\": \"192.168.196.2\"\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Deploy a service tunnel named 'SDP-from-192-168-178-90-to-192-168-75-61' connecting source device 192.168.178.90 to destination device 192.168.75.61. SDP ID is 9061. Transport type: MPLS, signaling: TLDP."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"tunnel\",\n  \"template_name\": \"MPLSTunnelsWithBGP\",\n  \"fill_values\": {\n    \"source-ne-id\": \"192.168.178.90\",\n    \"sdp-id\": \"9061\",\n    \"destination-ne-id\": \"192.168.75.61\",\n    \"name\": \"SDP-from-192-168-178-90-to-192-168-75-61\"\n  }\n}"}]}
