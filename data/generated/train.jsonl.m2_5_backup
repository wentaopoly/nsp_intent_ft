e[1].interface-name\": \"Sirius-Cluster-Worker-1\",\n    \"site[0].interface[1].sap.port-id\": \"lag-Cisco5-4x10GE\",\n    \"site[0].interface[1].ipv4.primary.address\": \"172.31.250.185\",\n    \"site[0].interface[1].ipv4.primary.prefix-length\": 30,\n    \"site[1].site-name\": \"VPRN-5947-SwiftLink\",\n    \"site[1].device-id\": \"192.168.163.147\",\n    \"site[1].ne-service-id\": 5947,\n    \"site[1].route-distinguisher\": \"64860:5947\",\n    \"site[1].vrf-import\": [\n      \"SwiftLink-VRF-Import\"\n    ],\n    \"site[1].vrf-export\": [\n      \"SwiftLink-VRF-Export\"\n    ],\n    \"site[1].interface[0].interface-name\": \"Gamma-Cluster-Master\",\n    \"site[1].interface[0].sap.port-id\": \"2/1/c2/4\",\n    \"site[1].interface[0].ipv4.primary.address\": \"172.22.255.241\",\n    \"site[1].interface[0].ipv4.primary.prefix-length\": 24,\n    \"site[1].interface[1].interface-name\": \"Gamma-Cluster-Worker-1\",\n    \"site[1].interface[1].sap.port-id\": \"2/1/c11/1\",\n    \"site[1].interface[1].ipv4.primary.address\": \"10.198.51.5\",\n    \"site[1].interface[1].ipv4.primary.prefix-length\": 24\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "We need to set up a new E-Pipe service for customer 5755. The connection goes from router 192.168.214.249 (port 2/1/c3/4) to router 192.168.85.227 (port 1/2/c1/3) on VLAN 1696. Name it 'Epipe-VLAN-1696-edge-site-to-colo', service ID 9946, MTU 1400. Please use SDP IDs 249227 and 227249 for the tunnel."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-1696-edge-site-to-colo\",\n    \"customer-id\": 5755,\n    \"ne-service-id\": 9946,\n    \"mtu\": 1400,\n    \"site-a.device-id\": \"192.168.214.249\",\n    \"site-a.endpoint[0].port-id\": \"2/1/c3/4\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 1696,\n    \"site-b.device-id\": \"192.168.85.227\",\n    \"site-b.endpoint[0].port-id\": \"1/2/c1/3\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 1696,\n    \"sdp[0].sdp-id\": \"249227\",\n    \"sdp[0].source-device-id\": \"192.168.214.249\",\n    \"sdp[0].destination-device-id\": \"192.168.85.227\",\n    \"sdp[1].sdp-id\": \"227249\",\n    \"sdp[1].source-device-id\": \"192.168.85.227\",\n    \"sdp[1].destination-device-id\": \"192.168.214.249\"\n  }\n}"}]}
