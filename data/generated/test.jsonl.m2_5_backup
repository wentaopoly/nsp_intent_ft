"site[0].interface[1].sap.port-id\": \"lag-Intel1-2x100GE\",\n    \"site[0].interface[1].ipv4.primary.address\": \"172.16.198.201\",\n    \"site[0].interface[1].ipv4.primary.prefix-length\": 24,\n    \"site[1].site-name\": \"VPRN-4705-NetFlow\",\n    \"site[1].device-id\": \"192.168.117.77\",\n    \"site[1].ne-service-id\": 4705,\n    \"site[1].route-distinguisher\": \"64645:4705\",\n    \"site[1].vrf-import\": [\n      \"NetFlow-VRF-Import\"\n    ],\n    \"site[1].vrf-export\": [\n      \"NetFlow-VRF-Export\"\n    ],\n    \"site[1].interface[0].interface-name\": \"Orion-Cluster-Master\",\n    \"site[1].interface[0].sap.port-id\": \"1/2/c9/1\",\n    \"site[1].interface[0].ipv4.primary.address\": \"172.19.230.175\",\n    \"site[1].interface[0].ipv4.primary.prefix-length\": 28,\n    \"site[1].interface[1].interface-name\": \"Orion-Cluster-Worker-1\",\n    \"site[1].interface[1].sap.port-id\": \"lag-Mellanox5-2x25GE\",\n    \"site[1].interface[1].ipv4.primary.address\": \"100.82.200.119\",\n    \"site[1].interface[1].ipv4.primary.prefix-length\": 24\n  }\n}"}]}
{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Deploy L3 VPN 'VPRN-2419-FlexNet' for customer 8261. Single site on device 192.168.159.144, NE service ID 2419. RD: 65240:2419. Import policy: FlexNet-VRF-Import, export policy: FlexNet-VRF-Export. Configure the following interfaces: Atlas-Cluster-Master on port lag-Intel9-2x100GE with IP 172.25.116.208/31; Atlas-Cluster-Worker-1 on port 2/2/c8/1 with IP 172.22.211.89/31."}, {"role": "assistant", "content": "{\n  \"intent_type\": \"vprn\",\n  \"template_name\": \"VPRNServiceTemplate\",\n  \"fill_values\": {\n    \"service-name\": \"VPRN-2419-FlexNet\",\n    \"customer-id\": 8261,\n    \"site[0].site-name\": \"VPRN-2419-FlexNet\",\n    \"site[0].device-id\": \"192.168.159.144\",\n    \"site[0].ne-service-id\": 2419,\n    \"site[0].route-distinguisher\": \"65240:2419\",\n    \"site[0].vrf-import\": [\n      \"FlexNet-VRF-Import\"\n    ],\n    \"site[0].vrf-export\": [\n      \"FlexNet-VRF-Export\"\n    ],\n    \"site[0].interface[0].interface-name\": \"Atlas-Cluster-Master\",\n    \"site[0].interface[0].sap.port-id\": \"lag-Intel9-2x100GE\",\n    \"site[0].interface[0].ipv4.primary.address\": \"172.25.116.208\",\n    \"site[0].interface[0].ipv4.primary.prefix-length\": 31,\n    \"site[0].interface[1].interface-name\": \"Atlas-Cluster-Worker-1\",\n    \"site[0].interface[1].sap.port-id\": \"2/2/c8/1\",\n    \"site[0].interface[1].ipv4.primary.address\": \"172.22.211.89\",\n    \"site[0].interface[1].ipv4.primary.prefix-length\": 31\n  }\n}"}]}
