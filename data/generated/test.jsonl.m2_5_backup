{"messages": [{"role": "system", "content": "You are an NSP (Network Services Platform) intent configuration assistant. Given a natural language description of a network service, output a JSON object with three fields: 'intent_type' (one of: epipe, tunnel, vprn), 'template_name' (the NSP template to use), and 'fill_values' (a flat dictionary of field paths and their values that should be filled into the intent template). Only include fields that differ from template defaults. Use dot notation for nested paths and [N] for array indices. Output only valid JSON, no explanations."}, {"role": "user", "content": "Deploy epipe: Epipe-VLAN-1017-headquarters-to-colo, cust=8413, svc-id=1802, mtu=9192, 192.168.167.38:1/1/c7/4 <-> 192.168.46.183:lag-Broadcom4-4x10GE, VLAN 1017, SDP 38183/18338"}, {"role": "assistant", "content": "{\n  \"intent_type\": \"epipe\",\n  \"template_name\": \"ePIPE-Service-Using-SDP\",\n  \"fill_values\": {\n    \"service-name\": \"Epipe-VLAN-1017-headquarters-to-colo\",\n    \"customer-id\": 8413,\n    \"ne-service-id\": 1802,\n    \"mtu\": 9192,\n    \"site-a.device-id\": \"192.168.167.38\",\n    \"site-a.endpoint[0].port-id\": \"1/1/c7/4\",\n    \"site-a.endpoint[0].outer-vlan-tag\": 1017,\n    \"site-b.device-id\": \"192.168.46.183\",\n    \"site-b.endpoint[0].port-id\": \"lag-Broadcom4-4x10GE\",\n    \"site-b.endpoint[0].outer-vlan-tag\": 1017,\n    \"sdp[0].sdp-id\": \"38183\",\n    \"sdp[0].source-device-id\": \"192.168.167.38\",\n    \"sdp[0].destination-device-id\": \"192.168.46.183\",\n    \"sdp[1].sdp-id\": \"18338\",\n    \"sdp[1].source-device-id\": \"192.168.46.183\",\n    \"sdp[1].destination-device-id\": \"192.168.167.38\"\n  }\n}"}]}
