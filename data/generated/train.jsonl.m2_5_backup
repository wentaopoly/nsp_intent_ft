\"lag-Nokia8-4x25GE\",\n    \"site[0].interface[1].ipv4.primary.address\": \"10.235.175.158\",\n    \"site[0].interface[1].ipv4.primary.prefix-length\": 30,\n    \"site[0].interface[2].interface-name\": \"Lambda-Cluster-Worker-2\",\n    \"site[0].interface[2].sap.port-id\": \"lag-Intel9-4x25GE\",\n    \"site[0].interface[2].ipv4.primary.address\": \"172.26.79.171\",\n    \"site[0].interface[2].ipv4.primary.prefix-length\": 28\n  }\n}"}]}
